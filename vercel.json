{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": null,
  "installCommand": null,
  "outputDirectory": ".",
  "cleanUrls": false,
  "trailingSlash": false,
  "redirects": [
    { "source": "/projects", "destination": "/portfolio.html", "permanent": true },
    { "source": "/projects/", "destination": "/portfolio.html", "permanent": true },
    { "source": "/portfolio", "destination": "/portfolio.html", "permanent": true },
    { "source": "/portfolio/", "destination": "/portfolio.html", "permanent": true },
    { "source": "/24hrs", "destination": "/24hrs.html", "permanent": true },
    { "source": "/24hrs/", "destination": "/24hrs.html", "permanent": true },
    { "source": "/contact", "destination": "/contact.html", "permanent": true },
    { "source": "/contact/", "destination": "/contact.html", "permanent": true },
    { "source": "/blog", "destination": "/blog.html", "permanent": true },
    { "source": "/blog/", "destination": "/blog.html", "permanent": true },
    { "source": "/whitelabel", "destination": "/whitelabel.html", "permanent": true },
    { "source": "/whitelabel/", "destination": "/whitelabel.html", "permanent": true },
    { "source": "/privacy", "destination": "/privacy.html", "permanent": true },
    { "source": "/privacy/", "destination": "/privacy.html", "permanent": true },
    { "source": "/terms", "destination": "/terms.html", "permanent": true },
    { "source": "/terms/", "destination": "/terms.html", "permanent": true },
    { "source": "/about", "destination": "/#about", "permanent": true },
    { "source": "/services", "destination": "/#services", "permanent": true },
    { "source": "/work", "destination": "/portfolio.html", "permanent": true },
    { "source": "/faq", "destination": "/#faq", "permanent": true },
    { "source": "/linkedin-video-downloader", "destination": "https://freetools.sarvaya.in/linkedin-video-downloader", "permanent": true },
    { "source": "/linkedin-video-downloader/", "destination": "https://freetools.sarvaya.in/linkedin-video-downloader", "permanent": true },
    { "source": "/freetools", "destination": "https://freetools.sarvaya.in", "permanent": true },
    { "source": "/freetools/:path*", "destination": "https://freetools.sarvaya.in/:path*", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(css|js|svg|png|jpg|jpeg|webp|gif|ico|woff2?)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
